# Zkopírujte do terraform.tfvars a upravte hodnoty
# NIKDY necommitujte terraform.tfvars do gitu!

aws_region   = "eu-central-1"
project_name = "myapp"
environment  = "prod"

# VPC
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["eu-central-1a", "eu-central-1b"]

# ECS / App
app_image         = "123456789.dkr.ecr.eu-central-1.amazonaws.com/myapp-app:latest"
app_port          = 3000
app_cpu           = 512
app_memory        = 1024
app_desired_count = 2
app_min_count     = 1
app_max_count     = 10

# Env proměnné (citlivé hodnoty raději do SSM Parameter Store)
app_environment_vars = {
  NODE_ENV = "production"
  PORT     = "3000"
}

# HTTPS (volitelné)
# certificate_arn = "arn:aws:acm:eu-central-1:123456789:certificate/xxx"
# domain_name     = "app.example.com"

# GitHub OIDC (pro bezheslo CI/CD autentizaci)
github_org  = "nazev-organizace-nebo-username"
github_repo = "aimtek"
